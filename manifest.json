{
  "manifest_version": 3,
  "name": "Browser Helper",
  "version": "1.0.0",
  "description": "浏览器工具箱：标签页管理 + JSON 格式化，一个插件搞定",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Helper - 浏览器工具箱",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "tabs",
    "bookmarks",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "打开 Browser Helper"
    }
  }
}
